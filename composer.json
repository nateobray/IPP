{
    "name": "obray/ipp",
    "description": "A PHP implemntation of the Internet Printing Protocol (IPP)",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "obray\\ipp\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": { 
            "obray\\ipp\\test\\": "test" 
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --testsuite unit",
        "test:unit": "vendor/bin/phpunit --testsuite unit",
        "test:integration": "vendor/bin/phpunit --testsuite integration",
        "test:fixtures": "vendor/bin/phpunit --testsuite unit --filter Recorded",
        "record:fixtures": "php scripts/record_real_fixtures.php"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "config": {
        "platform": {
            "php": "8.1.0"
        }
    }
}
